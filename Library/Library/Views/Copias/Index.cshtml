@model IEnumerable<Library.Models.Copia>

@{
    ViewBag.Title = "Catálogo de Copias";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Gestión de Autores</h5>
        @Html.ActionLink("+ Nuevo Autor", "Create", null, new { @class = "btn btn-success btn-sm" })
    </div>
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Título</th>
                    <th>Tipo de copia</th>
                    <th>Estado</th>
                    <th>Precio</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.Libro.titulo</td>
                        <td class="align-middle">@item.tipo</td>
                        <td class="align-middle">@item.estado</td>
                        <td class="align-middle">@item.precio</td>
                        <td class="text-end">
                            @Html.ActionLink("Editar", "Edit", new { id = item.id_copia }, new { @class = "btn btn-sm btn-primary" })
                            @Html.ActionLink("Detalles", "Details", new { id = item.id_copia }, new { @class = "btn btn-sm btn-info text-white" })
                            @Html.ActionLink("Eliminar", "Delete", new { id = item.id_copia }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>