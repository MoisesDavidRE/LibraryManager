@model IEnumerable<Library.Models.Venta>

@{
    ViewBag.Title = "Ventas";
}

<div class="container mt-4">
    <h2 class="text-center mb-4"> Lista de Ventas</h2>

    <p>
        @Html.ActionLink(" Crear Nueva Venta", "Create", null, new { @class = "btn btn-primary" })
    </p>

    <table class="table table-striped table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.fecha_venta)</th>
                <th>@Html.DisplayNameFor(model => model.total)</th>
                <th>@Html.DisplayNameFor(model => model.Cliente.nombre)</th>
                <th class="text-center">Acciones</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.fecha_venta)</td>
                    <td>
                        <span class="fw-bold text-success">
                            $ @Html.DisplayFor(modelItem => item.total)
                        </span>
                    </td>
                    <td>@Html.DisplayFor(modelItem => item.Cliente.nombre)</td>
                    <td class="text-center">
                        @Html.ActionLink("Editar ", "Edit", new { id = item.id_venta }, new { @class = "btn btn-sm btn-warning", title = "Editar" })
                        @Html.ActionLink("Detalles ", "Details", new { id = item.id_venta }, new { @class = "btn btn-sm btn-info", title = "Detalles" })
                        @Html.ActionLink("Borrar ", "Delete", new { id = item.id_venta }, new { @class = "btn btn-sm btn-danger", title = "Eliminar" })
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <nav aria-label="Paginación de ventas">
        <ul class="pagination justify-content-center">

            @* Botón Anterior *@
            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    @Html.ActionLink("«", "Index", new { page = ViewBag.CurrentPage - 1 }, new { @class = "page-link" })
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">«</span>
                </li>
            }

            @* Números de página *@
            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == ViewBag.CurrentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        @Html.ActionLink(i.ToString(), "Index", new { page = i }, new { @class = "page-link" })
                    </li>
                }
            }

            @* Botón Siguiente *@
            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    @Html.ActionLink("»", "Index", new { page = ViewBag.CurrentPage + 1 }, new { @class = "page-link" })
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">»</span>
                </li>
            }

        </ul>
    </nav>
</div>