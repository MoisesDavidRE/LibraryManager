@model IEnumerable<Library.Models.Cliente>

@{
    ViewBag.Title = "Catálogo de Clientes";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Gestión de Libros</h5>
        @Html.ActionLink("+ Nuevo Cliente", "Create", null, new { @class = "btn btn-success btn-sm" })
    </div>
    <div class="card-body">
        <table class="table table-striped table-hover">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Teléfono</th>
                    <th class="text-end">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="align-middle">@item.nombre</td>
                        <td class="align-middle">@item.email</td>
                        <td class="align-middle">@item.telefono</td>
                        <td class="text-end">
                            @Html.ActionLink("Editar", "Edit", new { id = item.id_cliente }, new { @class = "btn btn-sm btn-primary" })
                            @Html.ActionLink("Detalles", "Details", new { id = item.id_cliente }, new { @class = "btn btn-sm btn-info text-white" })
                            @Html.ActionLink("Eliminar", "Delete", new { id = item.id_cliente }, new { @class = "btn btn-sm btn-danger" })
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <nav aria-label="Paginación de clientes">
        <ul class="pagination justify-content-center">

            @if (ViewBag.CurrentPage > 1)
            {
                <li class="page-item">
                    @Html.ActionLink("«", "Index", new { page = ViewBag.CurrentPage - 1 }, new { @class = "page-link" })
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">«</span>
                </li>
            }

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                if (i == ViewBag.CurrentPage)
                {
                    <li class="page-item active">
                        <span class="page-link">@i</span>
                    </li>
                }
                else
                {
                    <li class="page-item">
                        @Html.ActionLink(i.ToString(), "Index", new { page = i }, new { @class = "page-link" })
                    </li>
                }
            }

            @if (ViewBag.CurrentPage < ViewBag.TotalPages)
            {
                <li class="page-item">
                    @Html.ActionLink("»", "Index", new { page = ViewBag.CurrentPage + 1 }, new { @class = "page-link" })
                </li>
            }
            else
            {
                <li class="page-item disabled">
                    <span class="page-link">»</span>
                </li>
            }

        </ul>
    </nav>
</div>