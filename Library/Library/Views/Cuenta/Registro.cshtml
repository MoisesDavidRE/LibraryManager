@model Library.ViewModels.RegistroViewModel

@{
    ViewBag.Title = "Registro de Usuario";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header bg-success text-white text-center">
                <h4 class="mb-0">Crear Nueva Cuenta</h4>
            </div>
            <div class="card-body">
                @using (Html.BeginForm("Registro", "Cuenta", FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="mb-3">
                        <label class="form-label fw-bold">Nombre Completo</label>
                        @Html.TextBoxFor(m => m.Nombre, new { @class = "form-control", placeholder = "Juan Pérez" })
                        @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Correo Electrónico</label>
                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control", placeholder = "ejemplo@libreria.com" })
                        @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Contraseña</label>
                        @Html.PasswordFor(m => m.Password, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.Password, "", new { @class = "text-danger" })
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold">Confirmar Contraseña</label>
                        @Html.PasswordFor(m => m.ConfirmarPassword, new { @class = "form-control" })
                        @Html.ValidationMessageFor(m => m.ConfirmarPassword, "", new { @class = "text-danger" })
                    </div>

                    <button type="submit" class="btn btn-success w-100 mb-3">Registrarse</button>

                    <div class="text-center">
                        @Html.ActionLink("¿Ya tienes cuenta? Inicia sesión aquí", "Login", "Cuenta", null, new { @class = "text-decoration-none" })
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
}